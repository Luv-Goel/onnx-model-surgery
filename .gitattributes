# Auto-detect text files and normalize line endings
* text=auto

# Python source
*.py text diff=python
*.pyw text diff=python

# ONNX model binaries (stored as-is, LFS recommended for large models)
*.onnx binary
*.onnx.zip binary
*.onnx.tar.gz binary

# Documentation
*.md text diff=markdown
*.rst text
*.txt text
CHANGELOG* text
README* text
LICENSE* text

# Config files
*.toml text
*.yaml text
*.yml text
*.json text diff=json
*.cfg text
*.ini text

# Scripts
*.sh text eol=lf
*.bash text eol=lf
*.bat text eol=crlf
*.ps1 text eol=crlf

# Git files
.gitattributes text
.gitignore text
.gitmodules text

# Generated/exported files
*.html text
*.css text
*.js text

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text
*.woff binary
*.woff2 binary
*.eot binary

# Archives
*.zip binary
*.tar.gz binary
*.gz binary
*.bz2 binary

# Lock files
uv.lock text
